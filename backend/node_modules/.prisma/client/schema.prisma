generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  nombre    String
  rol       String   @default("gestor") // admin | gestor | consulta
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Empleado {
  id           Int      @id @default(autoincrement())
  cod          String   @unique
  nom          String
  apell1       String
  apell2       String
  nif          String   @unique
  fecnac       String
  sexo         String
  pob          String
  prov         String
  tel1         String
  email        String
  delegacion   String
  empresa      String
  departamento String
  situacion    String   @default("activo") // activo | baja | vacaciones
  convenio     String
  turno        String
  modoPago     String   @default("Transferencia")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  nominas    Nomina[]
  cuadrantes Cuadrante[]
}

model Cliente {
  id           Int      @id @default(autoincrement())
  codCli       String   @unique
  nombreCli    String
  codPais      String   @default("ESP")
  codProvincia String
  codPostal    String
  email        String
  tipoTel1     String
  fechaAlta    String
  codTarifa    String
  codGrupoCli  String
  nivelFact    String   @default("M")
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cuadrantes Cuadrante[]
}

model Nomina {
  id          Int      @id @default(autoincrement())
  empleadoId  Int
  mes         String
  fecini      String
  fecfin      String
  diasNomina  Int
  devengado   Float
  deducciones Float
  liquido     Float
  cuotaSS     Float
  convenio    String
  categoria   String
  contrato    String
  delegacion  String
  grCotiz     String
  regimenSS   String
  paga        Boolean  @default(false)
  estado      String   @default("pendiente") // pendiente | calculada | proceso | pagada
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  empleado Empleado @relation(fields: [empleadoId], references: [id])
}

model Cuadrante {
  id         Int      @id @default(autoincrement())
  empleadoId Int
  clienteId  Int
  contrato   String
  turno      String
  fecha      String
  horas      String
  centro     String
  estado     String   @default("pendiente") // realizado | pendiente | incidencia
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  empleado Empleado @relation(fields: [empleadoId], references: [id])
  cliente  Cliente  @relation(fields: [clienteId], references: [id])
}

model Cuenta {
  id          Int     @id @default(autoincrement())
  codCta      String  @unique
  desCta      String
  desAbrev    String
  codGrupoCta String
  natCta      String // A | P | G | I
  ctaActiva   Boolean @default(true)
  generaAnl   Boolean @default(false)
}
